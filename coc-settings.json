{
  "css.colorDecorators.enable": true,
  "css.lint.duplicateProperties": "warning",
  "css.lint.unknownAtRules": "ignore",

  "coc.preferences.colorSupport": true,
  "coc.preferences.formatOnType": true,
  "coc.preferences.useQuickfixForLocations": true,

  "codeLens.enable": true,

  "diagnostic.infoSign": "i",
  "diagnostic.hintSign": "?",
  "diagnostic.errorSign": "x",
	"diagnostic.warningSign": "!",
	"diagnostic.enable": true,
  "diagnostic.highlightOffset": 9999999,
  "diagnostic.refreshOnInsertMode": true,

	"emmet.includeLanguages": {
	  "javascript": "javascriptreact",
	  "typescript": "typescriptreact"
	},

  "eslint.alwaysShowStatus": true,
  "eslint.autoFixOnSave": true,
  "eslint.format.enable": true,
  "eslint.run": "onType",

  "explorer.keyMappings.global": {
    "e": false,
    "o": ["wait", "expandable?", ["expanded?", "collapse", "expand"], "open"],
    "u": "indentPrev",
    "gs": ["wait", "reveal:select"]
  },
  "explorer.file.autoReveal": false,
  "explorer.file.root.template": "[icon] [title] [root]",
  "explorer.file.child.template": "[selection | clip | 1][indent][icon | 1] [filename growRight 1 omitRight 1] [diagnosticError | diagnosticWarning][git]",
  "explorer.file.showHiddenFiles": true,
  "explorer.floating.border.enable": true,
  "explorer.floating.contentWidth": -5,
  "explorer.git.icon.rootStatus.conflicted": "x",
  "explorer.git.icon.status.deleted": "-",
  "explorer.git.icon.status.modified": "~",
  "explorer.icon.enableNerdfont": true,
  "explorer.previewAction.onHover": false,
  "explorer.presets": {
    "staticLeft": {
      "position": "left",
      "width": 60
    },
    "staticRight": {
      "position": "right",
      "width": 40
    },
    "floatingCenter": {
      "position": "floating",
      "floating-position": "center",
      "floating-width": 120,
      "content-width": -20,
      "floating-height": -2,
      "open-action-strategy": "sourceWindow"
   }
  },

  "git.addedSign.text": "+",
  "git.removedSign.text": "-",
  "git.changedSign.text": "~",

  "javascript.suggestionActions.enabled": false,
  "javascript.format.enabled": true,
  "javascript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,

  "languageserver": {
    "golang": {
      "command": "gopls",
                "rootPatterns": [
                    "go.mod",
                    ".vim/",
                    ".git/",
                    ".hg/"
                ],
                "filetypes": ["go"],
                "initializationOptions": {
                "usePlaceholders": true
            }
      },

      "ccls": {
        "command": "ccls",
        "filetypes": [
          "c", "cpp", "cuda", "objc", "objcpp"],
          "rootPatterns": [
          ".ccls",
          ".ccls-root",
          "compile_commands.json",
          ".vim/",
          ".git/"
        ],
        "initializationOptions": {
          "cache": {
              "directory": "/tmp/.ccls-cache"
          },
          "client": {
              "snippetSupport": true
          }
        }
      }
    },

    "less.lint.duplicateProperties": "warning",

    "Lua.diagnostics.globals": ["love", "vim"],

    "python.jediEnabled": false,
    "python.autoComplete.addBrackets": true,
    "python.analysis.diagnosticPublishDelay": 500,

    "smartf.timeout": 2000,

    "snippets.extends": {
        "javascriptreact": ["javascript"],
        "typescriptreact": ["javascript"]
    },

    "suggest.completionItemKindLabels": {
        "keyword": "\uf1de",
        "variable": "\ue79b",
        "value": "\uf89f",
        "operator": "\u03a8",
        "function": "\u0192",
        "reference": "\ufa46",
        "constant": "\uf8fe",
        "method": "\uf09a",
        "struct": "\ufb44",
        "class": "\uf0e8",
        "interface": "\uf417",
        "text": "\ue612",
        "enum": "\uf435",
        "enumMember": "\uf02b",
        "module": "\uf40d",
        "color": "\ue22b",
        "property": "\ue624",
        "field": "\uf9be",
        "unit": "\uf475",
        "event": "\ufacd",
        "file": "\uf723",
        "folder": "\uf114",
        "snippet": "\ue60b",
        "typeParameter": "\uf728",
        "default": "\uf29c"
    },

    "tsserver.enableJavascript": true,

    "typescript.suggestionActions.enabled": true,
    "typescript.format.enabled": true,
    "typescript.format.insertSpaceAfterOpeningAndBeforeClosingNonemptyBraces": true,

    "yaml.customTags": [
        "!Equals sequence",
        "!FindInMap sequence",
        "!GetAtt",
        "!GetAZs",
        "!ImportValue",
        "!Join sequence",
        "!Ref",
        "!Select sequence",
        "!Split sequence",
        "!Sub"
	]
}